# purpl-brain — root environment variables
# Copy this to .env and fill in your values.
#
# This file controls docker-compose variable substitution ONLY.
# Runtime config for the API and workers lives in apps/api/.env
# (copy from apps/api/.env.example, .env.claude for Anthropic, or .env.local for Ollama).
#
# Only 3 variables are interpolated by docker-compose from this file:

# ── Ollama host URL (used by all workers inside Docker) ───────────────────────
# host.docker.internal resolves to the Docker host — do not change for local dev.
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# ── Drift detection threshold ─────────────────────────────────────────────────
# Cosine similarity cutoff for Stage A candidate search.
# 0.55 catches cross-technology conflicts (e.g. Qdrant vs Weaviate).
# Raise to 0.70+ only if you see too many false-positive alerts on a dense corpus.
DRIFT_SEMANTIC_THRESHOLD=0.55

# ── Web UI API base URL ───────────────────────────────────────────────────────
# Override if running the API on a non-default port or remote host.
NEXT_PUBLIC_API_URL=http://localhost:3001
