# purpl-brain — environment variables
# Copy this to .env and fill in your values.
#
# ── Two ways to run ────────────────────────────────────────────────────────────
#
#   A) Fully local with Ollama (default — tested, no API keys needed):
#      Install Ollama: https://ollama.com
#        ollama pull nomic-embed-text:v1.5   # embeddings
#        ollama pull qwen2.5:7b              # fast extraction
#        ollama pull llama3.1:8b             # query answering
#      Expect ~14s p50 query latency on a modern laptop.
#
#   B) Anthropic (faster — ~2s queries, requires API key):
#      Set LLM_PROVIDER=anthropic and fill in ANTHROPIC_API_KEY below.
#      Ollama still required for embeddings (nomic-embed-text:v1.5).

# ── LLM provider ───────────────────────────────────────────────────────────────
# "anthropic" or "ollama"
LLM_PROVIDER=ollama

# ── Option A: Fully local with Ollama (default — tested) ───────────────────────
# Pull models first:
#   ollama pull nomic-embed-text:v1.5   # embeddings — required for both options
#   ollama pull qwen2.5:7b              # fast extraction (strong JSON reliability)
#   ollama pull llama3.1:8b             # query answering (128k context, strong citation following)
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_FAST_MODEL=qwen2.5:7b
OLLAMA_SMART_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text:v1.5

# ── Option B: Anthropic (faster queries, requires API key) ─────────────────────
# Ollama still required for embeddings — pull nomic-embed-text:v1.5 first.
# Switch to this path by setting LLM_PROVIDER=anthropic above.
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5-20251001
# EXTRACTION_MODEL=claude-haiku-4-5-20251001

# ── Database ───────────────────────────────────────────────────────────────────
# NEO4J_AUTH: used by the neo4j container. Format: username/password.
# NEO4J_USER / NEO4J_PASSWORD: used by the API workers to connect.
# All three must stay consistent — username and password are the same in both.
# Change these before exposing Neo4j to any network.
NEO4J_AUTH=neo4j/change-me-strong-password
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-strong-password
SESSION_COOKIE_SECURE=false

# ── Auth ───────────────────────────────────────────────────────────────────────
# BRAIN_API_KEY: the key used by the web UI and MCP server.
# The API auto-registers this as a Bot Person in Neo4j on first boot.
# Keep this as dev-local for local testing (matches the pre-built web image default).
BRAIN_API_KEY=dev-local
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# ── Your project name ──────────────────────────────────────────────────────────
DEFAULT_PROJECT_ID=my_team_auth_service

# ── Tuning (safe to leave as defaults) ────────────────────────────────────────
DRIFT_SEMANTIC_THRESHOLD=0.55
DRIFT_TOP_K=3
CONTEXT_BUDGET=6000

# ── GitHub OAuth (optional — enables Login with GitHub in the web UI) ─────────
# Register at: https://github.com/settings/developers → OAuth Apps → New OAuth App
#   Homepage URL:            http://localhost:3000
#   Authorization callback:  http://localhost:3001/auth/github/callback
# GITHUB_CLIENT_ID=Ov23li...
# GITHUB_CLIENT_SECRET=...
# GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ── GitHub (optional — connect to ingest PRs and commits) ─────────────────────
# GITHUB_TOKEN=ghp_...
# GITHUB_WEBHOOK_SECRET=some-secret

# ── Slack (optional) ───────────────────────────────────────────────────────────
# Set SLACK_ENABLED=true to start the slack-listener worker on docker compose up.
# The worker exits immediately if SLACK_ENABLED is not true — safe to leave in compose.
# SLACK_ENABLED=true
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_CHANNEL_IDS=C01234,C05678

# ── Jira (optional) ────────────────────────────────────────────────────────────
# JIRA_BASE_URL=https://myorg.atlassian.net
# JIRA_WEBHOOK_SECRET=some-secret

# ── Drift notifications (optional) ────────────────────────────────────────────
# When set, the drift-detector POSTs a JSON payload to this URL on every
# LLM-confirmed conflict alert. Use a Slack incoming webhook, a custom endpoint,
# or a coordinator agent URL. Leave blank to disable.
# Payload: { alert_id, project_id, risk, challenged_decision_id,
#            challenged_decision_summary, challenging_content, reason,
#            actor, timestamp }
# DRIFT_WEBHOOK_URL=https://hooks.slack.com/services/...
