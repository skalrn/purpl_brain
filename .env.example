# purpl-brain — environment variables
# Copy this to .env and fill in your values.
#
# ── Two ways to run ────────────────────────────────────────────────────────────
#
#   A) Anthropic + OpenAI embeddings (recommended — fastest, no local models needed):
#      Set LLM_PROVIDER=anthropic, fill in ANTHROPIC_API_KEY + OPENAI_API_KEY.
#      OpenAI embeddings cost ~$0/day at test volume (text-embedding-3-small).
#
#   B) Fully local with Ollama (free, no external API keys needed):
#      Set LLM_PROVIDER=ollama and pull the models listed below.
#      Expect 3–10x slower responses depending on your hardware.
#      Install Ollama: https://ollama.com
#        ollama pull nomic-embed-text:v1.5   # embeddings
#        ollama pull gemma3n:e2b              # fast extraction
#        ollama pull gemma2:9b               # query answering

# ── LLM provider ───────────────────────────────────────────────────────────────
# "anthropic" or "ollama"
LLM_PROVIDER=anthropic

# ── Option A: Anthropic LLM + Ollama embeddings (not yet verified end-to-end) ──
# Requires Ollama running locally with nomic-embed-text:v1.5 pulled.
# Embeddings always use Ollama regardless of LLM provider — one key, one model.
#   ollama pull nomic-embed-text:v1.5
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-haiku-4-5-20251001
EXTRACTION_MODEL=claude-haiku-4-5-20251001

# ── Option B: Fully local with Ollama (tested) ─────────────────────────────────
# Pull models first:
#   ollama pull nomic-embed-text:v1.5   # embeddings — required for both options
#   ollama pull gemma3:4b               # fast extraction (smaller, runs on most hardware)
#   ollama pull gemma3:12b              # query answering (better reasoning, needs ~8GB RAM)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# OLLAMA_FAST_MODEL=gemma3:4b
# OLLAMA_SMART_MODEL=gemma3:12b
# OLLAMA_EMBED_MODEL=nomic-embed-text:v1.5

# ── Database ───────────────────────────────────────────────────────────────────
# Required by docker-compose.prod.yml. Format: username/password.
# Change this before exposing Neo4j to any network.
NEO4J_AUTH=neo4j/change-me-strong-password

# ── Auth ───────────────────────────────────────────────────────────────────────
# API key used by the web UI and MCP server to authenticate with the brain API.
# Keep this as dev-local for beta testing (matches the pre-built web image).
API_KEY=dev-local
SESSION_SECRET=change-me-to-a-random-string

# ── Your project name ──────────────────────────────────────────────────────────
DEFAULT_PROJECT_ID=my_team_auth_service

# ── Tuning (safe to leave as defaults) ────────────────────────────────────────
DRIFT_SEMANTIC_THRESHOLD=0.55
DRIFT_TOP_K=3
CONTEXT_BUDGET=6000

# ── GitHub OAuth (optional — enables Login with GitHub in the web UI) ─────────
# Register at: https://github.com/settings/developers → OAuth Apps → New OAuth App
#   Homepage URL:            http://localhost:3000
#   Authorization callback:  http://localhost:3001/auth/github/callback
# GITHUB_CLIENT_ID=Ov23li...
# GITHUB_CLIENT_SECRET=...
# GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ── GitHub (optional — connect to ingest PRs and commits) ─────────────────────
# GITHUB_TOKEN=ghp_...
# GITHUB_WEBHOOK_SECRET=some-secret

# ── Slack (optional) ───────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_CHANNEL_IDS=C01234,C05678

# ── Jira (optional) ────────────────────────────────────────────────────────────
# JIRA_BASE_URL=https://myorg.atlassian.net
# JIRA_WEBHOOK_SECRET=some-secret
