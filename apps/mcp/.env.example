# Purpl Brain MCP server configuration
# Copy to .env and fill in your values

# Base URL of the Purpl Brain API
BRAIN_API_URL=http://localhost:3741

# API key for authenticated deployments (leave blank for local dev without auth)
BRAIN_API_KEY=

# Agent identifier written into brain logs (default: claude-code)
# Change to "cursor" or your own identifier if running from a different client
BRAIN_AGENT_ID=claude-code

# Transport: "stdio" for local Claude Code / Cursor, "http" for remote clients
MCP_TRANSPORT=stdio

# Port for HTTP transport (only used when MCP_TRANSPORT=http)
MCP_PORT=3742
