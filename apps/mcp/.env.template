# Purpl Brain MCP Server — environment template
# Copy to .env and fill in values

# URL of the Purpl Brain API server
# Local:  http://localhost:3001
# AWS:    http://<alb-dns-name>  (from CDK output ApiUrl)
BRAIN_API_URL=http://localhost:3001

# API key for authenticated deployments (leave empty for local/beta use)
BRAIN_API_KEY=

# Transport: "stdio" (default, for Claude Code/Cursor) | "http" (for remote clients)
MCP_TRANSPORT=stdio

# Port for HTTP+SSE transport (only used when MCP_TRANSPORT=http)
MCP_PORT=3002
