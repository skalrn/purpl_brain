PORT=3001

# ── LLM provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=bedrock

# AWS region — must have Bedrock model access enabled in this region
AWS_REGION=us-east-1

# AWS credentials — leave blank on EC2/ECS (IAM role is used automatically)
# Only set these for local-to-AWS testing without an instance role
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Bedrock model IDs
# Use us. prefix for cross-region inference (higher availability)
BEDROCK_EXTRACTION_MODEL=us.anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_QUERY_MODEL=us.anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0

# ── Query engine tuning (Claude on Bedrock handles large context well) ─────────
QUERY_TOP_K=20
QUERY_CONTEXT_BUDGET=24000

# ── Infrastructure — replace with your AWS-hosted endpoints ───────────────────

# ElastiCache (Redis) — get endpoint from AWS console
REDIS_URL=redis://<your-elasticache-endpoint>:6379

# Neo4j — self-hosted on EC2 or Neo4j Aura
NEO4J_URI=bolt://<your-neo4j-host>:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-neo4j-password>

# Qdrant — self-hosted on EC2 or Qdrant Cloud
QDRANT_URL=http://<your-qdrant-host>:6333
QDRANT_COLLECTION=brain_chunks
# amazon.titan-embed-text-v2:0 output dimension (set to 256/512/1024 — must match pipeline)
QDRANT_VECTOR_SIZE=1024

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
# Must match the secret set in GitHub repo webhook settings
GITHUB_WEBHOOK_SECRET=<your-webhook-secret>

# ── IMPORTANT: after switching from local to AWS ──────────────────────────────
# QDRANT_VECTOR_SIZE changed 768 → 1024 (different embedding model).
# Run pipeline:reset once to recreate the Qdrant collection and re-embed all events:
#   npm run pipeline:reset -w apps/api
# Then restart all three workers to replay from events:raw.
