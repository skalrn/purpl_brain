PORT=3001

# ── LLM provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic

# Anthropic direct API — get key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Query engine tuning (Claude handles large context well) ───────────────────
QUERY_TOP_K=20
QUERY_CONTEXT_BUDGET=24000

# ── Infrastructure — all local via Docker Compose ─────────────────────────────
REDIS_URL=redis://localhost:6379
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=brain_chunks
# Embeddings still use Ollama locally (nomic-embed-text) — keep at 768
# Ollama must be running: ollama pull nomic-embed-text:v1.5
QDRANT_VECTOR_SIZE=768

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=local-dev-secret

# ── NOTE ──────────────────────────────────────────────────────────────────────
# Embeddings (embed.ts) still use Ollama regardless of LLM_PROVIDER.
# You need Ollama running for the embedding pipeline even with Claude as the LLM.
# If you previously ran with .env.local (same QDRANT_VECTOR_SIZE=768),
# no pipeline:reset is needed — existing vectors are compatible.
