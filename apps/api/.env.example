PORT=3001

# ── LLM provider ──────────────────────────────────────────────────────────────
# "ollama"     — local dev with Ollama (free, no API key)
# "anthropic"  — direct Anthropic API
# "bedrock"    — AWS Bedrock (uses IAM role or AWS_ACCESS_KEY_ID/SECRET)
LLM_PROVIDER=ollama

# Ollama — only used when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_FAST_MODEL=gemma3:4b
OLLAMA_SMART_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text:v1.5

# Anthropic direct API — only used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# AWS Bedrock — only used when LLM_PROVIDER=bedrock
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=       # omit on EC2/ECS — IAM role is used automatically
# AWS_SECRET_ACCESS_KEY=   # omit on EC2/ECS — IAM role is used automatically
BEDROCK_EXTRACTION_MODEL=us.anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_QUERY_MODEL=us.anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0

# ── Query engine tuning ───────────────────────────────────────────────────────
# QUERY_TOP_K: number of Qdrant chunks retrieved per query
#   12000 chars / gemma3:4b (local) — prevents context overflow on small models
#   24000 chars / Claude on Bedrock — full budget, better answer quality
QUERY_TOP_K=20
QUERY_CONTEXT_BUDGET=12000

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=brain_chunks
# Vector size must match the embedding model:
#   768  — nomic-embed-text:v1.5 (Ollama)
#  1024  — amazon.titan-embed-text-v2:0 (Bedrock)
# Changing this requires pipeline:reset to recreate the collection.
QDRANT_VECTOR_SIZE=768

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=your-webhook-secret
