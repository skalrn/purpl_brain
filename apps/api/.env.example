PORT=3001

# --- LLM provider ---
# "ollama" for local dev (free, no API key needed)
# "anthropic" for production
LLM_PROVIDER=ollama

# Ollama — only needed when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_FAST_MODEL=gemma3:4b
OLLAMA_SMART_MODEL=gemma3:12b

# Anthropic — only needed when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# --- Infrastructure ---
REDIS_URL=redis://localhost:6379
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
QDRANT_URL=http://localhost:6333

# --- GitHub ---
GITHUB_WEBHOOK_SECRET=your-webhook-secret
