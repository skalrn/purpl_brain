PORT=3001

# ── LLM provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama

# Ollama — local dev, no API key needed
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_FAST_MODEL=gemma3:4b
OLLAMA_SMART_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text:v1.5

# ── Query engine tuning (Ollama/gemma3:4b limits) ─────────────────────────────
# Small context budget prevents gemma3:4b from overflowing on broad queries
QUERY_TOP_K=20
QUERY_CONTEXT_BUDGET=12000

# ── Infrastructure — all local via Docker Compose ─────────────────────────────
REDIS_URL=redis://localhost:6379
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=brain_chunks
# nomic-embed-text:v1.5 output dimension
QDRANT_VECTOR_SIZE=768

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
# Leave blank to skip webhook signature verification locally
GITHUB_WEBHOOK_SECRET=local-dev-secret
